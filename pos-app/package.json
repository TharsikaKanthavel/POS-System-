{
  "name": "pos-app",
  "private": true,
  "version": "0.0.0",
  "description": "A POS Application",
  "author": "SAAI",
  "main": "electron/main.cjs",
  "type": "module",
  "build": {
    "appId": "com.saai.pos",
    "productName": "SAAI POS",
    "directories": {
      "output": "dist-electron-build"
    },
    "files": [
      "dist/**/*",
      "electron/**/*"
    ],
    "win": {
      "target": [
        "nsis"
      ]
    }
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "electron:dev": "concurrently \"npm run dev\" \"wait-on http://localhost:3000 && cross-env ELECTRON_START_URL=http://localhost:3000 electron electron/main.cjs\"",
    "electron:build": "vite build && electron-builder"
  },
  "dependencies": {
    "@tensorflow/tfjs": "^4.22.0",
    "dexie": "^4.2.1",
    "dexie-react-hooks": "^4.2.0",
    "prop-types": "^15.8.1",
    "react": "^19.2.0",
    "react-barcode": "^1.6.1",
    "react-dom": "^19.2.0",
    "react-icons": "^5.5.0",
    "react-router-dom": "^7.11.0",
    "react-to-print": "^3.2.0",
    "recharts": "^3.6.0",
    "vite-plugin-pwa": "^1.2.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/react": "^19.2.5",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "concurrently": "^8.2.2",
    "cross-env": "^7.0.3",
    "electron": "^28.1.0",
    "electron-builder": "^24.9.1",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "vite": "^7.2.4",
    "wait-on": "^7.2.0"
  }
}
